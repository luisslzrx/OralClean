---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="w-full py-20 px-8 bg-white min-h-screen flex items-center">
    <div class="max-w-4xl mx-auto text-center">

      <!-- 404 Number -->
      <div class="mb-8">
        <h1 class="text-[rgb(21,101,192)] text-8xl md:text-9xl font-bold leading-none">404</h1>
      </div>

      <!-- Error Message -->
      <div class="mb-12">
        <h2 class="text-[rgb(33,33,33)] text-3xl md:text-4xl font-bold mb-4">
          Página no encontrada
        </h2>
        <p class="text-gray-500 text-lg max-w-2xl mx-auto leading-relaxed">
          Lo sentimos, la página que buscas no existe o ha sido movida. 
          Te invitamos a volver al inicio y explorar nuestros servicios.
        </p>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center justify-center bg-[rgb(21,101,192)] text-white text-base font-semibold px-8 py-4 rounded-xl hover:bg-[rgb(30,136,229)] transition-colors">
          Volver al inicio
        </a>
        <a href="/Servicios" class="inline-flex items-center justify-center border border-gray-200 text-[rgb(33,33,33)] text-base font-semibold px-8 py-4 rounded-xl hover:bg-gray-50 transition-colors">
          Ver servicios
        </a>
      </div>

      <!-- Optional: Help Section -->
      <div class="mt-16 pt-12 border-t border-gray-100">
        <p class="text-gray-400 text-sm mb-4">
          ¿Necesitas ayuda? Contáctanos directamente
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <a href="/Contacto" class="flex items-center gap-2 text-[rgb(21,101,192)] hover:text-[rgb(30,136,229)] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span class="text-sm font-medium">Contacto</span>
          </a>
          <a href="tel:+1234567890" class="flex items-center gap-2 text-[rgb(21,101,192)] hover:text-[rgb(30,136,229)] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span class="text-sm font-medium">Llamar ahora</span>
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>
