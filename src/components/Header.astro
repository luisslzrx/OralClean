---

---

<!-- HEADER -->
<header class="w-full glass fixed top-0 left-0 right-0 z-50">
  <div class="max-w-6xl mx-auto px-8 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/index.html" class="flex items-center">
      <img src="/images/icono.png" width="80" height="80" alt="OralClean Logo" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#" class="flex items-center gap-1.5 text-sm font-medium text-[rgb(21,101,192)]">
        Home
      </a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">About Us</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">Services</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">Booking</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">Doctors/Team</a>
    </nav>

    <!-- Desktop Right Nav -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">FAQs</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">Contact</a>
    </nav>

    <!-- Mobile Menu Button -->
    <button class="md:hidden p-2 rounded-lg hover:bg-white/20 transition-colors" onclick="toggleMobileMenu()">
      <svg class="w-6 h-6 text-[rgb(33,33,33)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden glass">
    <nav class="flex flex-col px-8 py-4 space-y-4">
      <a href="#" class="text-sm font-medium text-[rgb(21,101,192)]">Home</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">About Us</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">Services</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">Booking</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">Doctors/Team</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">FAQs</a>
      <a href="#" class="text-sm text-[rgb(33,33,33)]/90 hover:text-[rgb(21,101,192)] transition-colors">Contact</a>
    </nav>
  </div>

</header>

<script>
  function toggleMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    if (menu) {
      menu.classList.toggle('hidden');
    }
  }

  // Cerrar menú al hacer click fuera
  document.addEventListener('click', function(event: MouseEvent) {
    const menu = document.getElementById('mobile-menu');
    const target = event.target as HTMLElement;
    const menuButton = target.closest('button[onclick="toggleMobileMenu()"]');
    
    if (menu && !menu.contains(target) && !menuButton) {
      menu.classList.add('hidden');
    }
  });

  // Cerrar menú al hacer resize a desktop
  window.addEventListener('resize', function() {
    const menu = document.getElementById('mobile-menu');
    if (window.innerWidth >= 768 && menu) {
      menu.classList.add('hidden');
    }
  });

  // Cerrar menú al presionar Escape
  document.addEventListener('keydown', function(event: KeyboardEvent) {
    const menu = document.getElementById('mobile-menu');
    if (event.key === 'Escape' && menu && !menu.classList.contains('hidden')) {
      menu.classList.add('hidden');
    }
  });
</script>