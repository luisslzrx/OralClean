<section class="w-full py-20 px-8 bg-[rgb(21,101,192)]">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block border border-white/20 text-white/70 text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-5">
        Nuestros Beneficios
      </span>
      <h2 class="text-white text-4xl md:text-5xl font-bold">¿Por qué elegir OralClean?</h2>
    </div>

    <!-- Cards Container - Scroll horizontal en móviles, grid en desktop -->
    <div class="flex overflow-x-auto snap-x snap-mandatory gap-5 md:grid md:grid-cols-3 md:overflow-visible diferenciadores-container">

      <!-- Card 1 -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="bg-white border border-white/10 rounded-2xl p-7 hover:border-[rgb(30,136,229)]/50 transition-colors h-full">
          <div class="w-12 h-12 bg-[rgb(21,101,192)] rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3"/>
            </svg>
          </div>
          <h3 class="text-[rgb(33,33,33)] text-lg font-semibold mb-3">Tecnología de precisión</h3>
          <p class="text-[rgb(33,33,33)]/60 text-sm leading-relaxed">Diagnósticos más exactos y tratamientos más eficientes con equipos actuales.</p>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="bg-white border border-white/10 rounded-2xl p-7 hover:border-[rgb(30,136,229)]/50 transition-colors h-full">
          <div class="w-12 h-12 bg-[rgb(21,101,192)] rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
            </svg>
          </div>
          <h3 class="text-[rgb(33,33,33)] text-lg font-semibold mb-3">Ambiente relajado</h3>
          <p class="text-[rgb(33,33,33)]/60 text-sm leading-relaxed">Espacios diseñados para que te sientas cómodo desde el primer momento.</p>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="bg-white border border-white/10 rounded-2xl p-7 hover:border-[rgb(30,136,229)]/50 transition-colors h-full">
          <div class="w-12 h-12 bg-[rgb(21,101,192)] rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
            </svg>
          </div>
          <h3 class="text-[rgb(33,33,33)] text-lg font-semibold mb-3">Atención personalizada</h3>
          <p class="text-[rgb(33,33,33)]/60 text-sm leading-relaxed">Cada tratamiento se adapta a tu salud, necesidades y presupuesto.</p>
        </div>
      </div>

    </div>

    <!-- Dots - solo móvil -->
    <div class="flex justify-center items-center gap-2 mt-6 md:hidden">
      <button class="diferenciadores-dot w-2 h-2 rounded-full bg-white transition-all duration-300" data-index="0"></button>
      <button class="diferenciadores-dot w-2 h-2 rounded-full bg-white/30 transition-all duration-300" data-index="1"></button>
      <button class="diferenciadores-dot w-2 h-2 rounded-full bg-white/30 transition-all duration-300" data-index="2"></button>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.querySelector('.diferenciadores-container');
    const dots = document.querySelectorAll('.diferenciadores-dot');

    if (!container || dots.length === 0) return;

    function updateDots(activeIndex: number) {
      dots.forEach(function (dot, index) {
        if (index === activeIndex) {
          dot.classList.add('bg-white');
          dot.classList.remove('bg-white/30');
        } else {
          dot.classList.remove('bg-white');
          dot.classList.add('bg-white/30');
        }
      });
    }

    function scrollToCard(index: number) {
      const cards = container?.querySelectorAll('.snap-start');
      if (container && cards && cards[index]) {
        cards[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        updateDots(index);
      }
    }

    dots.forEach(function (dot, index) {
      dot.addEventListener('click', function () {
        scrollToCard(index);
      });
    });

    // Scroll listener
    var scrollTimeout: number;
    container.addEventListener('scroll', function () {
      clearTimeout(scrollTimeout);
      scrollTimeout = window.setTimeout(function () {
        const scrollLeft = container.scrollLeft;
        const firstCard = container.querySelector('.snap-start') as HTMLElement;
        const cardWidth = firstCard?.offsetWidth || 320;
        const calculatedIndex = Math.round(scrollLeft / cardWidth);
        const clampedIndex = Math.max(0, Math.min(calculatedIndex, 2));
        
        updateDots(clampedIndex);
      }, 50);
    });

    // Inicializar primer dot como activo
    updateDots(0);
  });
</script>