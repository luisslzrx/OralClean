    <!-- Two column layout -->
    <div class="bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-sm">
      <div class="flex flex-col lg:flex-row min-h-[500px]">

        <!-- LEFT: Image -->
        <div class="lg:w-1/2 relative">
          <img
            src="../images/Ortodoncia.webp"
            alt="Tratamientos dentales"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <!-- Overlay azul -->
          <div class="absolute inset-0 bg-gradient-to-r from-[rgb(21,101,192)]/60 via-[rgb(21,101,192)]/30 to-transparent"></div>
        </div>

        <!-- RIGHT: Content -->
        <div class="lg:w-1/2 p-10 flex items-center">
          <div class="space-y-4 w-full">

            <!-- Accordion Item 1 -->
            <div class="border border-gray-200 rounded-xl overflow-hidden">
              <button class="accordion-trigger w-full px-6 py-4 text-left flex items-center justify-between hover:bg-gray-50 transition-colors">
