<script>
(function () {
  var activeIndex = 0;

  function activate(index) {
    // Items
    document.querySelectorAll('.acc-item').forEach(function (item) {
      var i = parseInt(item.getAttribute('data-index'));
      var chevron = item.querySelector('.acc-chevron');
      if (i === index) {
        item.style.borderLeft = '3px solid rgb(21,101,192)';
        item.style.background = 'rgb(238,238,238)';
        chevron.style.transform = 'rotate(180deg)';
        chevron.style.color = 'rgb(21,101,192)';
      } else {
        item.style.borderLeft = '3px solid transparent';
        item.style.background = '';
        chevron.style.transform = 'rotate(0deg)';
        chevron.style.color = '';
      }
    });

    // Panels
    document.querySelectorAll('.acc-panel').forEach(function (panel) {
      var p = parseInt(panel.getAttribute('data-panel'));
      if (p === index) {
        panel.classList.remove('hidden');
      } else {
        panel.classList.add('hidden');
      }
    });

    activeIndex = index;
  }

  // Bind clicks
  document.querySelectorAll('.acc-item').forEach(function (item) {
    item.querySelector('.acc-trigger').addEventListener('click', function () {
      activate(parseInt(item.getAttribute('data-index')));
    });
  });

  // Init first
  activate(0);
})();
</script>
