<section class="w-full py-20 px-8 bg-white">
  <div class="max-w-6xl mx-auto">

    <!-- Top: Header + intro -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
      <div>
        <span class="inline-block bg-[rgb(21,101,192)] text-white text-xs font-semibold uppercase tracking-widest px-5 py-2 rounded-full mb-5">
          Planes de cuidado preventivo
        </span>
        <h2 class="text-[rgb(33,33,33)] text-4xl md:text-5xl font-bold leading-tight max-w-lg">
          ¿Por qué un<br>plan dental?
        </h2>
      </div>
      <p class="text-gray-500 text-base leading-relaxed max-w-sm">
        La mayoría de los problemas dentales se pueden evitar. Un plan preventivo te mantiene un paso adelante — siempre.
      </p>
    </div>

    <!-- Split: reasons left + visual right -->
    <div class="flex flex-col lg:flex-row gap-5">

      <!-- LEFT: Single content block -->
      <div class="flex-1">
        <div class="space-y-6">
          <div class="flex gap-5">
            <div class="w-12 h-12 rounded-xl bg-[rgb(21,101,192)] flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-[rgb(33,33,33)] text-lg font-bold mb-2">Evitas tratamientos costosos</h3>
              <p class="text-gray-500 text-sm leading-relaxed">
                Una limpieza periódica cuesta una fracción de lo que cuesta tratar una caries avanzada, una endodoncia o un implante. Invertir poco ahora evita gastar mucho después.
              </p>
            </div>
          </div>
          
          <div class="flex gap-5">
            <div class="w-12 h-12 rounded-xl bg-[rgb(21,101,192)] flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 10.607z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-[rgb(33,33,33)] text-lg font-bold mb-2">Detectas problemas a tiempo</h3>
              <p class="text-gray-500 text-sm leading-relaxed">
                Las revisiones periódicas permiten identificar caries, enfermedad periodontal u otros problemas en etapas tempranas, cuando el tratamiento es más simple y menos invasivo.
              </p>
            </div>
          </div>
          
          <div class="flex gap-5">
            <div class="w-12 h-12 rounded-xl bg-[rgb(21,101,192)] flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
              </svg>
            </div>
            <div>
              <h3 class="text-[rgb(33,33,33)] text-lg font-bold mb-2">Mantienes tu salud dental constante</h3>
              <p class="text-gray-500 text-sm leading-relaxed">
                Sin un plan, es fácil postergar las visitas. Con un plan anual tienes todo programado: limpiezas, revisiones y seguimiento continuo para que tu salud bucal nunca quede descuidada.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: stats card -->
      <div class="lg:w-80 flex flex-col gap-4">
        <!-- Big stat -->
        <div class="bg-[rgb(21,101,192)] rounded-2xl p-7 text-white flex flex-col justify-between">
          <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
            </svg>
          </div>
          <div>
            <p class="text-5xl font-bold leading-none mb-2">80<span class="text-2xl">%</span></p>
            <p class="text-white/70 text-sm leading-relaxed">
              de los problemas dentales graves son prevenibles con revisiones regulares y limpieza profesional.
            </p>
          </div>
        </div>

        <!-- Mini stat -->
        <div class="bg-[rgb(238,238,238)] border border-gray-100 rounded-2xl p-6 flex items-center gap-5">
          <div class="w-10 h-10 rounded-xl bg-[rgb(238,238,238)] flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-[rgb(21,101,192)]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
            </svg>
          </div>
          <div>
            <p class="text-[rgb(33,33,33)] text-xl font-bold leading-none">4 limpiezas</p>
            <p class="text-gray-400 text-xs mt-1">incluidas al año</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>