---

---

<!-- HERO SECTION -->
<section class="w-full min-h-screen flex items-center justify-center bg-[rgb(238,238,238)] px-4 py-8">
  <div class="w-full max-w-6xl flex flex-col md:flex-row gap-4 items-stretch mt-16 md:mt-20">

    <!-- ============ LEFT PANEL ============ -->
    <div class="flex-1 bg-white rounded-3xl p-7 md:p-12 flex flex-col justify-between shadow-sm">

      <!-- Rating Badge -->
      <div>
        <span class="inline-flex items-center gap-2 bg-white rounded-full px-4 py-2 text-sm font-medium text-[rgb(33,33,33)] shadow-sm border border-[rgb(238,238,238)]">
          <span class="w-2.5 h-2.5 rounded-full bg-[rgb(21,101,192)] inline-block"></span>
          5.0/4.9 Reviews
        </span>
      </div>

      <!-- Headline + Subtext -->
      <div class="mt-6 mb-5">
        <h1 class="text-[#0d3b38] text-3xl md:text-5xl font-bold leading-tight">
          Confianza y resultados en cada sonrisa
        </h1>
        <p class="mt-4 text-[rgb(33,33,33)]/70 text-sm leading-relaxed">
          Descubre OralClean, donde transformamos más que sonrisas: mejoramos tu seguridad y bienestar. Nuestro compromiso es brindarte tratamientos dentales precisos, cómodos y con resultados que realmente se notan.
        </p>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-3 mb-6">
        <button class="flex-1 sm:flex-none bg-[rgb(21,101,192)] text-white text-sm font-medium px-6 py-3 rounded-xl hover:bg-[rgb(30,136,229)] transition-colors">
          Agendar cita
        </button>
        <button class="flex-1 sm:flex-none border border-[rgb(21,101,192)] text-[rgb(21,101,192)] text-sm font-medium px-6 py-3 rounded-xl hover:bg-[rgb(21,101,192)] hover:text-white transition-colors">
          Comienza hoy
        </button>
      </div>

      <!-- Bottom Cards -->
      <div class="flex gap-3 mt-auto">

        <!-- Card 1 -->
        <div class="flex-1 bg-[rgb(238,238,238)] rounded-2xl p-4 flex flex-col justify-between min-h-[110px]">
          <div class="flex items-start justify-between">
            <div class="bg-white rounded-lg p-2">
              <svg class="w-5 h-5 text-[rgb(21,101,192)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <button class="w-6 h-6 rounded-full bg-[rgb(21,101,192)] flex items-center justify-center text-white hover:bg-[rgb(30,136,229)] transition-colors">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
          <div class="mt-3">
            <p class="text-[rgb(33,33,33)] font-semibold text-xs leading-snug">Atención inmediata</p>
            <p class="text-[rgb(33,33,33)]/60 text-xs mt-0.5">Agenda rápida sin complicaciones</p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="flex-1 bg-[rgb(238,238,238)] rounded-2xl p-4 flex flex-col justify-between min-h-[110px]">
          <div class="flex items-start justify-between">
            <div class="bg-white rounded-lg p-2">
              <svg class="w-5 h-5 text-[rgb(21,101,192)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <button class="w-6 h-6 rounded-full bg-[rgb(21,101,192)] flex items-center justify-center text-white hover:bg-[rgb(30,136,229)] transition-colors">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
          <div class="mt-3">
            <p class="text-[rgb(33,33,33)] font-semibold text-xs leading-snug">Resultados garantizados</p>
            <p class="text-[rgb(33,33,33)]/60 text-xs mt-0.5">Tratamientos efectivos y medibles</p>
          </div>
        </div>

      </div>
    </div>

    <!-- ============ RIGHT PANEL ============ -->
    <div class="flex-1 relative rounded-3xl overflow-hidden min-h-[380px] md:min-h-[500px]">

      <!-- Background photo -->
      <img
        src="../images/cliente-dentista.webp"
        alt="Dental procedure"
        class="absolute inset-0 w-full h-full object-cover object-center"
      />

      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/50"></div>

      <!-- Widget: 20% badge -->
      <div class="absolute top-5 right-5">
        <div class="glass rounded-xl px-4 py-2 text-white font-semibold text-sm">
          20% ↗
        </div>
      </div>

      <!-- Widget: Experiencia OralClean -->
      <div class="absolute bottom-5 left-4 right-4 md:left-6 md:right-6">
        <div class="glass rounded-2xl p-4 md:p-5 text-white">

          <p class="text-white/70 text-xs font-medium mb-3 uppercase tracking-wider">Experiencia OralClean</p>

          <div class="flex items-end justify-between mb-3">
            <div>
              <p class="text-3xl font-bold">+95%</p>
              <p class="text-white/60 text-xs mt-0.5">de pacientes satisfechos</p>
            </div>
            <p class="text-white/60 text-xs max-w-[140px] text-right leading-relaxed">
              Tecnología avanzada para resultados más rápidos
            </p>
          </div>

          <div class="space-y-1.5 pt-3 border-t border-white/15">
            <div class="flex items-center gap-2">
              <span class="w-4 h-4 rounded-full bg-[rgb(21,101,192)] flex items-center justify-center flex-shrink-0">
                <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
              </span>
              <span class="text-white/80 text-xs">Evaluación completa en una sola visita</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-4 h-4 rounded-full bg-[rgb(21,101,192)] flex items-center justify-center flex-shrink-0">
                <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
              </span>
              <span class="text-white/80 text-xs">Plan personalizado desde el inicio</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>