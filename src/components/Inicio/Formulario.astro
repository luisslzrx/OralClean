---

---

<section id="formulario" class="w-full py-14 md:py-20 px-5 md:px-8 bg-white">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-10 md:gap-16">

    <!-- Left: Text -->
    <div class="flex-1 w-full">
      <span class="inline-block bg-[rgb(21,101,192)] text-white text-xs font-semibold uppercase tracking-widest px-5 py-2 rounded-full mb-6">
        Agenda tu cita
      </span>
      <h2 class="text-[rgb(33,33,33)] text-3xl md:text-4xl font-bold leading-tight mb-4">
        Tu sonrisa empieza con una consulta
      </h2>
      <p class="text-[rgb(33,33,33)]/70 text-base leading-relaxed mb-8">
        Completa el formulario y nos pondremos en contacto para confirmar.
        Primera valoración sin costo.
      </p>

      <ul class="space-y-4">
        <li class="flex items-center gap-3">
          <div class="w-7 h-7 rounded-lg bg-[rgb(238,238,238)] flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-[rgb(21,101,192)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
          </div>
          <span class="text-[rgb(33,33,33)]/70 text-sm">Respuesta en menos de 24 horas</span>
        </li>
        <li class="flex items-center gap-3">
          <div class="w-7 h-7 rounded-lg bg-[rgb(238,238,238)] flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-[rgb(21,101,192)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
          </div>
          <span class="text-[rgb(33,33,33)]/70 text-sm">Sin compromiso de contratación</span>
        </li>
        <li class="flex items-center gap-3">
          <div class="w-7 h-7 rounded-lg bg-[rgb(238,238,238)] flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-[rgb(21,101,192)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
          </div>
          <span class="text-[rgb(33,33,33)]/70 text-sm">Plan de tratamiento personalizado</span>
        </li>
      </ul>
    </div>

    <!-- Right: Form Card -->
    <div class="flex-1 w-full bg-[rgb(238,238,238)] rounded-2xl p-6 md:p-8">
      <h3 class="text-[rgb(33,33,33)] text-lg font-semibold mb-6">Solicitar cita</h3>

      <div class="space-y-5">
        <div>
          <label class="block text-[rgb(33,33,33)] text-sm font-medium mb-1.5">Nombre completo</label>
          <input
            type="text"
            placeholder="Tu nombre"
            class="w-full bg-white border border-[rgb(238,238,238)] rounded-xl px-4 py-3 text-sm text-[rgb(33,33,33)] placeholder-[rgb(33,33,33)]/40 outline-none focus:border-[rgb(21,101,192)] focus:ring-2 focus:ring-[rgb(21,101,192)]/10 transition"
          />
        </div>

        <div>
          <label class="block text-[rgb(33,33,33)] text-sm font-medium mb-1.5">Teléfono</label>
          <input
            type="tel"
            placeholder="55 0000 0000"
            class="w-full bg-white border border-[rgb(238,238,238)] rounded-xl px-4 py-3 text-sm text-[rgb(33,33,33)] placeholder-[rgb(33,33,33)]/40 outline-none focus:border-[rgb(21,101,192)] focus:ring-2 focus:ring-[rgb(21,101,192)]/10 transition"
          />
        </div>

        <div>
          <label class="block text-[rgb(33,33,33)] text-sm font-medium mb-1.5">¿En qué podemos ayudarte?</label>
          <textarea
            rows="4"
            placeholder="Describe tu consulta..."
            class="w-full bg-white border border-[rgb(238,238,238)] rounded-xl px-4 py-3 text-sm text-[rgb(33,33,33)] placeholder-[rgb(33,33,33)]/40 outline-none focus:border-[rgb(21,101,192)] focus:ring-2 focus:ring-[rgb(21,101,192)]/10 transition resize-none"
          ></textarea>
        </div>

        <button class="w-full flex items-center justify-center gap-2.5 bg-[rgb(21,101,192)] text-white text-sm font-semibold py-3.5 rounded-xl hover:bg-[rgb(30,136,229)] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
          </svg>
          Enviar solicitud
        </button>
      </div>
    </div>

  </div>
</section>