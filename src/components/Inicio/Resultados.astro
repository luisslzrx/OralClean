<section class="w-full py-20 px-8 bg-white">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <h2 class="text-[#0d3b38] text-4xl md:text-5xl font-bold mb-10">
      Nuestro consultorio y nuestros resultados
    </h2>

    <!-- Grid Container - Scroll horizontal en móviles, grid especial en desktop -->
    <div class="flex overflow-x-auto snap-x snap-mandatory gap-4 md:grid md:grid-cols-3 md:grid-rows-2 md:overflow-visible resultados-container" style="height: 520px;">

      <!-- Grande izquierda: Antes / Después -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full md:row-span-2 snap-start">
        <div class="relative rounded-2xl overflow-hidden group cursor-pointer h-full">
          <img
            src="../images/antes.webp"
            alt="Clientes satisfechos"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-5 left-5">
            <span class="text-white text-lg font-bold">Clientes satisfechos</span>
          </div>
        </div>
      </div>

      <!-- Top center: Consultorio -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="relative rounded-2xl overflow-hidden group cursor-pointer h-full">
          <img
            src="../images/consultorio.webp"
            alt="Consultorio"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
          <div class="absolute bottom-4 left-4">
            <span class="text-white text-base font-bold">Consultorio</span>
          </div>
        </div>
      </div>

      <!-- Top right: Ortodoncia -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="relative rounded-2xl overflow-hidden group cursor-pointer h-full">
          <img
            src="../images/Ortodoncia-servicios.webp"
            alt="Ortodoncia"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
          <div class="absolute bottom-4 left-4">
            <span class="text-white text-base font-bold">Ortodoncia</span>
          </div>
        </div>
      </div>

      <!-- Bottom center: Estética -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="relative rounded-2xl overflow-hidden group cursor-pointer h-full">
          <img
            src="../images/estetica.webp"
            alt="Estética"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
          <div class="absolute bottom-4 left-4">
            <span class="text-white text-base font-bold">Estética dental</span>
          </div>
        </div>
      </div>

      <!-- Bottom right: Equipo -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="relative rounded-2xl overflow-hidden group cursor-pointer h-full">
          <img
            src="../images/Proteccion.webp"
            alt="Equipo"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
          <div class="absolute bottom-4 left-4">
            <span class="text-white text-base font-bold">Nuestro equipo</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Dots - solo móvil -->
    <div class="flex justify-center items-center gap-2 mt-6 md:hidden">
      <button class="resultados-dot w-2 h-2 rounded-full bg-[rgb(21,101,192)] transition-all duration-300" data-index="0"></button>
      <button class="resultados-dot w-2 h-2 rounded-full bg-[rgb(21,101,192)]/30 transition-all duration-300" data-index="1"></button>
      <button class="resultados-dot w-2 h-2 rounded-full bg-[rgb(21,101,192)]/30 transition-all duration-300" data-index="2"></button>
      <button class="resultados-dot w-2 h-2 rounded-full bg-[rgb(21,101,192)]/30 transition-all duration-300" data-index="3"></button>
      <button class="resultados-dot w-2 h-2 rounded-full bg-[rgb(21,101,192)]/30 transition-all duration-300" data-index="4"></button>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.querySelector('.resultados-container');
    const dots = document.querySelectorAll('.resultados-dot');

    if (!container || dots.length === 0) return;

    function updateDots(activeIndex: number) {
      dots.forEach(function (dot, index) {
        if (index === activeIndex) {
          dot.classList.add('bg-[rgb(21,101,192)]');
          dot.classList.remove('bg-[rgb(21,101,192)]/30');
        } else {
          dot.classList.remove('bg-[rgb(21,101,192)]');
          dot.classList.add('bg-[rgb(21,101,192)]/30');
        }
      });
    }

    function scrollToCard(index: number) {
      const cards = container?.querySelectorAll('.snap-start');
      if (container && cards && cards[index]) {
        cards[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        updateDots(index);
      }
    }

    dots.forEach(function (dot, index) {
      dot.addEventListener('click', function () {
        scrollToCard(index);
      });
    });

    // Scroll listener
    var scrollTimeout: number;
    container.addEventListener('scroll', function () {
      clearTimeout(scrollTimeout);
      scrollTimeout = window.setTimeout(function () {
        const scrollLeft = container.scrollLeft;
        const firstCard = container.querySelector('.snap-start') as HTMLElement;
        const cardWidth = firstCard?.offsetWidth || 320;
        const calculatedIndex = Math.round(scrollLeft / cardWidth);
        const clampedIndex = Math.max(0, Math.min(calculatedIndex, 4));
        
        updateDots(clampedIndex);
      }, 50);
    });

    // Inicializar primer dot como activo
    updateDots(0);
  });
</script>