<section class="w-full py-20 px-8 bg-[#f0fafa]">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block bg-[rgb(21,101,192)] text-white text-xs font-semibold uppercase tracking-widest px-5 py-2 rounded-full mb-5">
        Testimonios
      </span>
      <h2 class="text-[#0d3b38] text-4xl md:text-5xl font-bold">Lo que dicen nuestros pacientes</h2>
    </div>

    <!-- Cards Container - Scroll horizontal en móviles, grid en desktop -->
    <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 md:grid md:grid-cols-3 md:overflow-visible comentarios-container">

      <!-- Card 1 -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="bg-white border border-gray-100 rounded-2xl p-7 shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between h-full">
          <div>
            <div class="flex gap-1 mb-5">
              <span class="text-amber-400 text-lg">★★★★★</span>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-7">
              "El blanqueamiento fue increíble. El proceso fue muy cómodo y me explicaron cada paso detalladamente."
            </p>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#dff4f4] flex items-center justify-center text-[#0d5c56] text-xs font-bold flex-shrink-0">
              MG
            </div>
            <div>
              <p class="text-[#0d3b38] text-sm font-semibold">María González</p>
              <p class="text-gray-400 text-xs">Blanqueamiento dental</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="bg-white border border-gray-100 rounded-2xl p-7 shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between h-full">
          <div>
            <div class="flex gap-1 mb-5">
              <span class="text-amber-400 text-lg">★★★★★</span>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-7">
              "Llevé a mis hijos y la atención fue excelente. Consultorio moderno y personal muy profesional y amable."
            </p>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#dff4f4] flex items-center justify-center text-[#0d5c56] text-xs font-bold flex-shrink-0">
              CR
            </div>
            <div>
              <p class="text-[#0d3b38] text-sm font-semibold">Carlos Ramírez</p>
              <p class="text-gray-400 text-xs">Limpieza dental</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="flex-shrink-0 w-[calc(100vw-4rem)] md:w-full snap-start">
        <div class="bg-white border border-gray-100 rounded-2xl p-7 shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between h-full">
          <div>
            <div class="flex gap-1 mb-5">
              <span class="text-amber-400 text-lg">★★★★★</span>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-7">
              "Mi tratamiento de ortodoncia ha sido excelente. Los resultados mes a mes son muy motivadores. ¡100% recomendado!"
            </p>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#dff4f4] flex items-center justify-center text-[#0d5c56] text-xs font-bold flex-shrink-0">
              AL
            </div>
            <div>
              <p class="text-[#0d3b38] text-sm font-semibold">Ana López</p>
              <p class="text-gray-400 text-xs">Ortodoncia</p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Dots - solo móvil -->
    <div class="flex justify-center items-center gap-2 mt-6 md:hidden">
      <button class="comentarios-dot w-2 h-2 rounded-full bg-[rgb(21,101,192)] transition-all duration-300" data-index="0"></button>
      <button class="comentarios-dot w-2 h-2 rounded-full bg-[rgb(21,101,192)]/30 transition-all duration-300" data-index="1"></button>
      <button class="comentarios-dot w-2 h-2 rounded-full bg-[rgb(21,101,192)]/30 transition-all duration-300" data-index="2"></button>
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.querySelector('.comentarios-container');
    const dots = document.querySelectorAll('.comentarios-dot');

    if (!container || dots.length === 0) return;

    function updateDots(activeIndex: number) {
      dots.forEach(function (dot, index) {
        if (index === activeIndex) {
          dot.classList.add('bg-[rgb(21,101,192)]');
          dot.classList.remove('bg-[rgb(21,101,192)]/30');
        } else {
          dot.classList.remove('bg-[rgb(21,101,192)]');
          dot.classList.add('bg-[rgb(21,101,192)]/30');
        }
      });
    }

    function scrollToCard(index: number) {
      const cards = container?.querySelectorAll('.snap-start');
      if (container && cards && cards[index]) {
        cards[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        updateDots(index);
      }
    }

    dots.forEach(function (dot, index) {
      dot.addEventListener('click', function () {
        scrollToCard(index);
      });
    });

    // Scroll listener
    var scrollTimeout: number;
    container.addEventListener('scroll', function () {
      clearTimeout(scrollTimeout);
      scrollTimeout = window.setTimeout(function () {
        const scrollLeft = container.scrollLeft;
        const firstCard = container.querySelector('.snap-start') as HTMLElement;
        const cardWidth = firstCard?.offsetWidth || 320;
        const calculatedIndex = Math.round(scrollLeft / cardWidth);
        const clampedIndex = Math.max(0, Math.min(calculatedIndex, 2));
        
        updateDots(clampedIndex);
      }, 50);
    });

    // Inicializar primer dot como activo
    updateDots(0);
  });
</script>